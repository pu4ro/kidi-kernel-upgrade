# Copy to .env and adjust. Loaded automatically by the Makefile.
# Precedence: command-line args > .env > Makefile defaults.
# Values below are the ones used on the reference node (RHEL 9.3 -> 9.6, k8s 1.23.17).

# =================== Target OS / ISO ===================
# Path to the TARGET-version DVD ISO (the version you upgrade TO).
ISO = /root/rhel-9.6-x86_64-dvd.iso

# Where to loop-mount the ISO.
MOUNT = /mnt/rhel-iso

# Current (source) and target OS minor versions.
EXPECTED_CURRENT = 9.3
TARGET_VERSION = 9.6

# Pre-upgrade snapshot directory.
BACKUP_ROOT = /root/kernel-upgrade-verify/backup

# Set to 1 to skip the current-version check.
FORCE = 0

# Package-level rollback (make rollback-pkgs): source-version DVD ISO + the
# dnf history transaction id of the upgrade to undo (see 'dnf history list').
SOURCE_ISO = /root/rhel-9.3-x86_64-dvd.iso
SOURCE_MOUNT = /mnt/rhel-src
# UNDO_ID = 4

# =================== Kubernetes install ===================
# createrepo'd directory holding the k8s + containerd RPMs (offline bundle).
LOCAL_RPM_REPO = /root/repo

# Directory of raw .rpm files for 'make local-repo' to index (defaults to LOCAL_RPM_REPO).
# Only needed if the directory has no repodata/ yet.
RPM_SRC = /root/repo

# kubeadm/kubelet/kubectl version to install.
K8S_VERSION = 1.23.17

# Pod network CIDR (must match the CNI; Flannel default is 10.244.0.0/16).
POD_CIDR = 10.244.0.0/16

# CRI endpoint (containerd).
CRI_SOCKET = /run/containerd/containerd.sock

# CNI manifest applied after kubeadm init.
FLANNEL_URL = https://github.com/flannel-io/flannel/releases/latest/download/kube-flannel.yml

# Air-gapped DNS fix: if set, 'make set-dns' writes this to /etc/resolv.conf
# (needed so kubeadm can pull images from registry.k8s.io).
DNS_SERVER = 8.8.8.8

# kubeconfig used by verify-k8s / k8s-status to reach the API.
KUBECONFIG = /etc/kubernetes/admin.conf

# =================== Custom repo (optional, Phase 2) ===================
# Extra repo(s) to ALSO enable during the OS upgrade (kept disabled by default
# so the kernel upgrade does not touch the k8s/containerd packages).
# Case A: repo already configured on the system -> just list its id(s).
# EXTRA_REPOS = internal,thirdparty
#
# Case B: let the Makefile create the repo -> give id + baseurl (+ optional key).
# CUSTOM_REPO_ID = internal
# CUSTOM_REPO_URL = http://repo.local/rhel9/internal
# CUSTOM_REPO_GPGKEY = file:///etc/pki/rpm-gpg/RPM-GPG-KEY-internal
